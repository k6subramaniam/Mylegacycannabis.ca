# ═══════════════════════════════════════════════════
# My Legacy Cannabis — E2E Test Environment Variables
# Copy to .env.test and fill in your values
# ═══════════════════════════════════════════════════

# Base URL for testing (local dev or Railway production)
TEST_BASE_URL=http://localhost:5000
# TEST_BASE_URL=https://mylegacycannabisca-production.up.railway.app

# Test user credentials (create a dedicated test account)
TEST_USER_EMAIL=testuser@mylegacycannabis.ca
TEST_USER_OTP=123456

# Test admin credentials
TEST_ADMIN_EMAIL=admin@mylegacycannabis.ca
TEST_ADMIN_OTP=654321

# Set to 'true' if you have a /api/auth/test-otp endpoint
# that returns the real OTP for a given email (dev/staging only)
TEST_OTP_BYPASS=false
